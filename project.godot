; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited if needed.

config_version=5

[application]

config/name="AstroCode"
run/main_scene="res://scenes/world/main_world.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

GameManager="*res://scripts/autoloads/game_manager.gd"
InventoryManager="*res://scripts/autoloads/inventory_manager.gd"
TimeManager="*res://scripts/autoloads/time_manager.gd"
CraftingManager="*res://scripts/autoloads/crafting_manager.gd"
RobotManager="*res://scripts/autoloads/robot_manager.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"
DialogueManager="*res://scripts/autoloads/dialogue_manager.gd"
CircuitManager="*res://scripts/autoloads/circuit_manager.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"

